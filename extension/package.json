{
  "name": "rubber-duck",
  "displayName": "RubberDuck",
  "description": "Talk through bugs with an LLM. Sends your debugger state (stack, variables) to the agent so you can rubber-duck debug.",
  "version": "0.1.0",
  "publisher": "rubber-duck",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onCommand:rubber-duck.sendDebugContextToAgent",
    "onCommand:rubber-duck.copyDebugContext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rubber-duck.sendDebugContextToAgent",
        "title": "RubberDuck: Send debug context to agent"
      },
      {
        "command": "rubber-duck.copyDebugContext",
        "title": "RubberDuck: Copy debug context to clipboard"
      }
    ],
    "keybindings": [
      {
        "command": "rubber-duck.sendDebugContextToAgent",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "inDebugMode && debugState == 'stopped'"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
